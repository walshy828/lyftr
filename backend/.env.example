# Server
PORT=3000
ENV=development

# Database (SQLite default — no changes needed for local dev)
DB_TYPE=sqlite
DB_PATH=./data/lyftr.db

# PostgreSQL (only used if DB_TYPE=postgres)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=lyftr
# DB_USER=postgres
# DB_PASSWORD=

# Auth
JWT_SECRET=change-me-in-production-min-32-chars!!
JWT_EXPIRY=3600

# Admin — comma-separated emails allowed to call the /admin/* endpoints
# (exercise-library sync/reset). Unset = admin surface closed to everyone.
# ADMIN_EMAILS=you@example.com

# Demo seeding — the demo user (demo@lyftr.local / password123) and demo
# workout/food data. Defaults: on in development, OFF in production.
# Set explicitly to override either default.
# SEED_DEMO=false

# CORS — comma-separated allow-list of client origins permitted to call the API.
# Use * to allow any origin (the API is Bearer-token based, so no cookies are at risk).
CORS_ORIGIN=http://localhost:5173

# ExerciseDB (RapidAPI)
# Sign up free at https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
# Paste your key below — exercises are fetched once and stored locally.
# EXERCISEDB_KEY=your_rapidapi_key_here

# Nutrition label photo import (optional) — pick ONE provider and set its key.
# Leave VISION_PROVIDER unset to disable the feature (scan requests return 503).
# VISION_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
# GEMINI_API_KEY=your_gemini_key_here

# Optional: override the model used by the active VISION_PROVIDER. Leave unset
# to use the built-in default (currently claude-opus-4-8 / gpt-4o / gemini-2.0-flash).
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-2.0-flash
