<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="Lyftr"
        android:icon="@drawable/ic_launcher"
        android:theme="@style/Theme.Lyftr"
        android:allowBackup="false"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Declares this app as having a companion Wear OS app, which is what
             lets Play/adb install the :wear module alongside this one on a
             paired watch. -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Lyftr">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".sync.SessionSyncService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Receives DataItem/Message events from the watch even when
             SessionSyncService isn't already running, and starts it. -->
        <service
            android:name=".sync.WearListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/lyftr/action" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:path="/lyftr/request-session" />
            </intent-filter>
        </service>

    </application>
</manifest>
